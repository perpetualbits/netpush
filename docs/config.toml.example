# canopy config — copy to ~/.config/canopy/config.toml (or pass --config FILE).
# Every key is optional; omitted keys keep their built-in default (shown below).
# CLI flags (--vantage, --range, …) override anything set here.
#
# No secrets live here: the NetBox token is fetched from `pass` (the entry named by
# `token_pass`) or the $CANOPY_NETBOX_TOKEN environment variable.

# Default CIDR range to browse.
range      = "10.87.3.0/24"

# SSH host to run NetBox + DNS queries from (must reach NetBox and internal DNS).
vantage    = "dns1.astron.nl"

# SSH host on the target L2 to run the ARP/ping probe from.
probe_host = "takkie.astron.nl"

# NetBox base URL.
netbox_url = "https://netbox.astron.nl"

# `pass` entry holding the NetBox API token.
token_pass = "astron/netbox.astron.nl/dns_api_token"

# Max concurrent reverse-DNS lookups during a sweep. Lower is gentler on the DNS
# server (and the authoritative reverse server behind it); higher is faster.
dns_concurrency = 64

# Max concurrent ping probes. Bounds processes on probe_host and the ARP burst on
# the target L2.
probe_concurrency = 64

# Authoritative server to try reverse-DNS zone transfers (AXFR) from. When set and
# transfer is permitted, one AXFR per /24 replaces hundreds of per-address lookups —
# far lighter on the DNS server. Empty (default) keeps the per-address sweep.
# reverse_axfr_server = "ntserver1.astron.nl"

# canopy config — copy to ~/.config/canopy/config.toml (or pass --config FILE).
# Every key is optional; omitted keys keep their built-in default (shown below).
# CLI flags (--vantage, --range, …) override anything set here.
#
# SITES: to point canopy at a specific organization's estate, put that estate in
# ~/.config/canopy/conf.d/<site>.toml and select it with `canopy --site <name>`
# (default: astron). The site file is merged OVER this base config, so keep personal
# defaults (token_pass, concurrency) here and the per-org bits (netbox_url, vantage, jump,
# dns_servers) in the site file. See docs/site.toml.example.
#
# No secrets live here: the NetBox token is fetched from `pass` (the entry named by
# `token_pass`) or the $CANOPY_NETBOX_TOKEN environment variable.

# CIDR range to browse. Optional: leave it unset and run with --live to have canopy
# DISCOVER the address space from the sources (NetBox aggregates + the reverse zones the
# dns_servers below master) instead of naming a block. A --range flag or this key pins a
# single block for a focused view. Offline with nothing pinned, canopy shows the demo /24.
# range    = "10.87.3.0/24"

# SSH host to run NetBox + DNS queries from (must reach NetBox and internal DNS).
vantage    = "dns1.astron.nl"

# SSH ProxyJump chain to reach every host canopy SSHes to (vantage, probe, DNS servers),
# e.g. "bastion.astron.nl" or a chain "portal.lofar.eu,inner.host". Empty (default) means
# connect directly. Per-server overrides live on each [[dns_servers]] entry, and your
# ~/.ssh/config is still honoured on top.
# jump = "bastion.astron.nl"

# SSH host on the target L2 to run the ARP/ping probe from.
probe_host = "takkie.astron.nl"

# NetBox base URL.
netbox_url = "https://netbox.astron.nl"

# `pass` entry holding the NetBox API token.
token_pass = "astron/netbox.astron.nl/dns_api_token"

# Max concurrent reverse-DNS lookups during a sweep. Lower is gentler on the DNS
# server (and the authoritative reverse server behind it); higher is faster.
dns_concurrency = 64

# Max concurrent ping probes. Bounds processes on probe_host and the ARP burst on
# the target L2.
probe_concurrency = 64

# Authoritative server to try reverse-DNS zone transfers (AXFR) from. When set and
# transfer is permitted, one AXFR per /24 replaces hundreds of per-address lookups —
# far lighter on the DNS server. Empty (default) keeps the per-address sweep. Also the
# fallback AXFR server for any reverse zone no [[dns_servers]] entry below claims.
# reverse_axfr_server = "ntserver1.astron.nl"

# The DNS estate: the servers of the network and the zones each masters. Optional — with
# no [[dns_servers]] entry canopy uses the single `vantage` (+ `reverse_axfr_server`)
# above, exactly as before. Listing servers lets canopy route each reverse-zone transfer
# to the server that actually masters it (longest-prefix match on the reverse block), and
# route forward names to their zone's server (longest-suffix match on the name).
#
# Per server:
#   name          short label for logs / the plan preview
#   host          the server's own hostname/IP — the `dig @host` AXFR target
#   vantage       SSH host to reach it from (omit to use the global `vantage`)
#   jump          SSH ProxyJump to reach it (omit to use the global `jump`)
#   forward_zones domain suffixes it masters (e.g. "nfra.nl")
#   reverse_zones reverse blocks it masters, as CIDRs (e.g. "10.0.0.0/8")
#
# [[dns_servers]]
# name          = "dns1"
# host          = "dns1.astron.nl"
# forward_zones = ["nfra.nl", "astron.nl"]
#
# [[dns_servers]]
# name          = "ntserver1"
# host          = "ntserver1.nfra.nl"
# reverse_zones = ["10.0.0.0/8"]

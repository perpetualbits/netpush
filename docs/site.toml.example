# Example site file — copy to ~/.config/canopy/conf.d/astron.toml and select with
# `canopy --site astron` (astron is the default site, so `canopy` alone also uses it).
#
# A "site" is one organization's network estate: everything in that NetBox, reached
# through that org's vantage/jump hosts. This file is merged OVER ~/.config/canopy/config.toml,
# so it only needs the per-org bits; personal defaults (token_pass, concurrency) can stay
# in the base config. Point canopy at another organization by adding conf.d/<other>.toml.

# Where this org's NetBox and internal DNS are reached from, and the bastion to get there.
vantage    = "dns1.astron.nl"
jump       = "bastion.astron.nl"        # or a chain, e.g. "portal.lofar.eu,inner.host"

# Host for the ARP/ping probe — a jump/bastion is a good choice: it sits close to the
# internal L2s and is reachable directly, so probe_jump stays empty. Set probe_jump only if
# the probe host itself sits behind another bastion.
probe_host = "bastion.astron.nl"
# probe_jump = ""

netbox_url = "https://netbox.astron.nl"

# The forward domains this site OWNS. Used by `canopy --discover-dns` to (1) seed the SOA
# probes — so an owned zone like lofar.eu is found even if no NetBox host names it — and
# (2) filter the result, keeping only servers under these domains. Without this, discovery
# also picks up servers your NetBox merely refers to (SURFnet's reverse master for the
# 145.124.0.0/16 they delegated you, a peer university, root/blackhole servers).
domains = ["astron.nl", "nfra.nl", "camras.nl", "lofar.eu", "lofar", "control.lofar", "offline.lofar"]

# The DNS estate: which server masters which zones, so canopy routes each reverse-zone
# transfer (and, later, each forward write) to the right box. Each server may set its own
# `vantage`/`jump`; omitted, they fall back to the site-wide values above.

[[dns_servers]]
name          = "dns1"
host          = "dns1.astron.nl"
forward_zones = ["nfra.nl", "astron.nl"]

[[dns_servers]]
name          = "ntserver1"                # Windows reverse master (RDP-only; PTRs are manual)
host          = "ntserver1.nfra.nl"
reverse_zones = ["10.0.0.0/8"]

[[dns_servers]]
name          = "lcs020"                   # LOFAR control-network DNS
host          = "lcs020.control.lofar"
jump          = "portal.lofar.eu"          # reached through the LOFAR portal
forward_zones = ["control.lofar", "lofar"]

[[dns_servers]]
name          = "ns1-lofar"
host          = "ns1.lofar.eu"
forward_zones = ["lofar.eu"]
